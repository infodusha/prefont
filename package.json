{
  "name": "prefont",
  "version": "0.3.0",
  "description": "",
  "homepage": "https://github.com/infodusha/prefont#readme",
  "bugs": {
    "url": "https://github.com/infodusha/prefont/issues"
  },
  "license": "Apache-2.0",
  "author": "infodusha",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/infodusha/prefont.git"
  },
  "bin": {
    "prefont": "./dist/cli/bin.js"
  },
  "files": [
    "dist",
    "schema.json",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/client/index.js",
  "types": "./dist/client/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    }
  },
  "scripts": {
    "prebuild": "pnpm clean && pnpm schema",
    "build": "tsc --build && chmod +x dist/cli/bin.js",
    "dev": "tsc --build --watch",
    "clean": "rm -rf dist",
    "schema": "node tools/generate-schema.ts && oxfmt schema.json",
    "example": "pnpm -F prefont-example",
    "lint": "oxlint",
    "fmt": "oxfmt"
  },
  "dependencies": {
    "playwright-core": "^1.59.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.63.0",
    "typescript": "~6.0.3"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.0"
}
